# Variabili Supabase (trovabili nel Dashboard Supabase -> Project Settings -> API)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Variabile per operazioni Administrative (Service Role Key - NON ESPORRE SUL FRONTEND)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# API Key per l'Assistente AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# API Key per invio email (Resend)
RESEND_API_KEY=your_resend_api_key_here
